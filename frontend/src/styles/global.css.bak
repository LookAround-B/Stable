}
.care-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.horse-info {
  background: white;
  padding: 15px;
  border-radius: 6px;
  border-left: 4px solid #9b59b6;
  margin-top: 10px;
}
.horse-info p {
  margin: 8px 0;
  color: #2c3e50;
}
.teams-container {
  background: white;
  border-radius: 8px;
  padding: 30px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  margin-bottom: 30px;
}
.teams-container h2 {
  color: #2c3e50;
  margin-bottom: 20px;
  font-size: 1.5rem;
  border-bottom: 2px solid #9b59b6;
  padding-bottom: 10px;
}
.horses-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  margin-top: 20px;
}
.horse-card {
  background: #f9f9f9;
  border: 2px solid #e0e0e0;
  border-radius: 8px;
  padding: 1.5rem;
