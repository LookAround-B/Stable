}
.access-denied p {
  font-size: 1rem;
  color: #666;
  margin-bottom: 2rem;
  max-width: 400px;
}
.btn-back {
  background-color: #1976d2;
  color: white;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: 4px;
