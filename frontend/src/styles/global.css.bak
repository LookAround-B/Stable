  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.action-cell {
  text-align: center;
  display: flex;
  gap: 8px;
}
.exited-text {
  color: #27ae60;
  font-weight: 600;
  font-size: 12px;
}
.no-entries {
