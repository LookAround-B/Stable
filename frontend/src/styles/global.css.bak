  gap: 1rem;
  flex-wrap: wrap;
}
.supply-tag {
  display: inline-block;
  padding: 0.4rem 0.75rem;
  border-radius: 4px;
  font-size: 0.85rem;
  font-weight: 600;
  color: white;
}
.supply-tag.woodchips {
  background-color: #8b6f47;
}
.supply-tag.bichali {
  background-color: #8b7355;
}
.supply-tag.boosa {
