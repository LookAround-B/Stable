  color: #555;
  font-weight: 500;
  font-size: 14px;
}
.date-filter .form-input {
  width: 180px;
  padding: 8px 12px;
}
.mode-selection, .person-type-selection {
  margin-bottom: 20px;
  padding: 15px;
  background: white;
  border-radius: 6px;
  border: 2px solid #ecf0f1;
}
.mode-label, .type-label {
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 10px;
  font-size: 14px;
}
.mode-buttons, .type-buttons {
  display: flex;
  gap: 10px;
}
.mode-btn, .type-btn {
  flex: 1;
  padding: 10px 15px;
  border: 2px solid #ddd;
  background: white;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 14px;
}
.mode-btn:hover, .type-btn:hover {
  border-color: #3498db;
  background: #ecf8ff;
}
.mode-btn.active, .type-btn.active {
  background: #3498db;
  color: white;
  border-color: #3498db;
}
.visitor-section {
  background: white;
  padding: 15px;
  border-radius: 6px;
