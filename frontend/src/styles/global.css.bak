  white-space: nowrap;
}
.total-price {
  font-weight: 600;
  color: #388e3c;
}
.care-team-page {
  padding: 30px;
  max-width: 1400px;
  margin: 0 auto;
}
.care-team-page h1 {
  color: #2c3e50;
