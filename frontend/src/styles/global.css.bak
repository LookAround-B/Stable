  font-size: 14px;
  color: #2c3e50;
  margin-top: 0;
  margin-bottom: 15px;
  font-weight: 600;
}
.divider {
  text-align: center;
  margin: 1.5rem 0;
  color: #999;
  font-weight: 500;
  font-size: 0.9rem;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.new-visitor-form {
  background: #fafbfc;
  padding: 15px;
  border-radius: 6px;
  border-left: 4px solid #3498db;
}
.form-row:last-child {
  margin-bottom: 0;
}
.btn-warning {
  background-color: #f39c12;
  color: white;
  width: 100%;
  padding: 12px;
}
.btn-warning:hover {
  background-color: #d68910;
  box-shadow: 0 4px 12px rgba(243, 156, 18, 0.3);
}
.btn-small {
  padding: 0.5rem 0.75rem;
  font-size: 0.85rem;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
  flex: 1;
}
.btn-exit {
  background-color: #3498db;
  color: white;
}
.btn-exit:hover {
  background-color: #2980b9;
}
.register-table-wrapper {
  overflow-x: auto;
  margin-top: 15px;
}
.register-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.register-table thead {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}
.register-table th {
  padding: 15px;
  text-align: left;
  font-weight: 600;
  border: none;
}
.register-table td {
  padding: 12px 15px;
  border-bottom: 1px solid #ecf0f1;
}
.register-table tbody tr {
  transition: background-color 0.2s ease;
}
.register-table tbody tr:hover {
  background-color: #f8f9fa;
}
.register-table tbody tr.exited {
  opacity: 0.7;
}
.register-table tbody tr.active {
  background-color: #fffaf0;
}
.register-table tbody tr:last-child td {
  border-bottom: none;
}
.person-name {
  font-weight: 600;
  color: #2c3e50;
}
.person-badge {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 20px;
