  font-size: 28px;
  color: #2c3e50;
  margin-bottom: 5px;
  font-weight: 600;
}
.gate-header .subtitle {
  color: #7f8c8d;
  font-size: 14px;
}
.gate-content {
  display: flex;
  flex-direction: column;
  gap: 30px;
}
.entry-section, .register-section {
  background: white;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  padding: 25px;
}
.date-filter {
  display: flex;
  gap: 10px;
  align-items: center;
}
