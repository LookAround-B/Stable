  padding: 20px;
  border-radius: 6px;
  border: 1px solid #e9ecef;
}
.feed-inputs-grid .form-group {
  margin-bottom: 0;
}
.records-section {
  background: white;
  padding: 30px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}
.records-table .horse-name {
  font-weight: 600;
  color: #667eea;
}
.records-table .notes {
  max-width: 200px;
  word-wrap: break-word;
  font-size: 13px;
  color: #777;
}
.summary-section {
  background: white;
  padding: 20px;
  border-radius: 4px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  background-color: #f8f9fa;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 15px;
  margin-bottom: 20px;
}
.summary-table-wrapper {
  overflow-x: auto;
}
.summary-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.summary-table thead {
  background-color: #f5f7fa;
  border-bottom: 2px solid #ddd;
}
.summary-table th {
  padding: 10px;
  text-align: left;
  font-weight: 600;
  color: white;
  background-color: #34495e;
