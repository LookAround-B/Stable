}
.groceries-table tbody tr:hover {
  background-color: #f9f9f9;
}
.groceries-table td {
  padding: 12px 16px;
  border-right: 1px solid #eee;
}
.groceries-table td:last-child {
  border-right: none;
}
.name-cell {
