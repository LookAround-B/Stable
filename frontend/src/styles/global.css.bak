  color: #7f8c8d;
  font-size: 16px;
}
.groom-worksheet-page {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem;
}
.groom-worksheet-page h1 {
  color: #333;
